{
  "name": "liveprintjs",
  "version": "1.3.0",
  "description": "Script for record your screen",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "buildStaging": "gulp --gulpfile gulpfile.cjs buildStaging",
    "buildDevelop": "gulp --gulpfile gulpfile.cjs buildDevelop",
    "buildProduction": "gulp --gulpfile gulpfile.cjs buildProduction",
    "watch": "gulp --gulpfile gulpfile.cjs watch",
    "push-changes": "git push",
    "upload:staging": "node --env-file=.env scripts/uploadScript.js staging",
    "upload:develop": "node --env-file=.env scripts/uploadScript.js develop",
    "upload:production": "node --env-file=.env scripts/uploadScript.js production",
    "deploy:staging": "npm run buildStaging && node --env-file=.env scripts/uploadScript.js staging --activate",
    "deploy:develop": "npm run buildDevelop && node --env-file=.env scripts/uploadScript.js develop --activate",
    "deploy:production": "npm run buildProduction && node --env-file=.env scripts/uploadScript.js production --activate"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/record-screen/liveprintJs.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/record-screen/liveprintJs/issues"
  },
  "homepage": "https://github.com/record-screen/liveprintJs#readme",
  "dependencies": {
    "gulp-concat": "^2.6.1",
    "gulp-rename": "^2.0.0",
    "gulp-uglify": "^3.0.2",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "rrweb": "^2.0.0-alpha.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "gulp": "^5.0.1",
    "convex": "^1.17.0",
    "gulp-replace": "^1.1.4",
    "webpack": "^5.88.2",
    "webpack-cli": "^7.0.2"
  }
}
